# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Fundación PRO-21
# Copiar a .env.local y completar los valores reales.
# NUNCA subir .env.local a GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── URL del sitio (sin barra al final) ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://fundacionpro21.org

# ── Cloudflare R2 — Almacenamiento de imágenes ───────────────────────────────
# Obtener en: dash.cloudflare.com → R2 → Manage API tokens
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=pro21-media
# Reemplazar <account-id> con el Account ID de Cloudflare
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# URL pública del bucket (si se habilita acceso público)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── Resend — Formulario de contacto ──────────────────────────────────────────
# Obtener en: resend.com → API Keys
# Plan gratuito: 3.000 emails/mes, 100/día
RESEND_API_KEY=

# ── Email de la fundación (destino de mensajes del formulario) ───────────────
CONTACT_EMAIL=contacto@fundacionpro21.org

# ── Analytics (opcional — decidir con la fundación) ──────────────────────────
# Google Analytics 4: obtener en analytics.google.com
NEXT_PUBLIC_GA_ID=

# Vercel Analytics: se activa automáticamente en el dashboard de Vercel
# No requiere variable de entorno adicional

# ── GitHub (para Decap CMS) ──────────────────────────────────────────────────
# El CMS usa OAuth de GitHub. Configurar en GitHub → Settings → OAuth Apps
# Estos valores van en el dashboard de Decap/Netlify Identity, NO aquí.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
